PORT=5000
NODE_ENV=development
# URL gốc API (không có /api) — chỉ dùng khi chạy local
APP_URL=http://localhost:5000

# ⚠️ DEV: dùng MySQL local — KHÔNG ghi Railway production vào file .env
# (tránh sửa/xóa dữ liệu thật khi npm run dev)
# Production chỉ cấu hình trên Vercel / GitHub Secrets.

# MySQL — local
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=he_thong_quan_ly_thieu_nhi_thanh_the

# MySQL — Railway (từ Vercel / máy dev: dùng MYSQL_PUBLIC_URL, KHÔNG dùng mysql.railway.internal)
# DB_HOST=<public-host từ Railway, ví dụ xxx.proxy.rlwy.net>
# DB_PORT=<public-port, ví dụ 29182>
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=railway

# JWT
JWT_SECRET=
JWT_EXPIRE=7d

# Optional
GROQ_API_KEY=

